# Normalize text to LF in the repo by default.
* text=auto eol=lf

# Windows batch scripts must keep CRLF.
*.bat text eol=crlf

# The Gradle wrapper script must stay LF so it runs on Unix/CI.
gradlew text eol=lf

# Binaries — never touch line endings.
*.jar binary
*.ico binary
*.png binary
*.jpg binary
*.webp binary
*.keystore binary
*.jks binary
